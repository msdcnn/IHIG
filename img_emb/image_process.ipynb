WORKING_PATH = "./"
 
def load_data():
    data_set=dict()
    train_set = []
    val_set = []
    test_set = []
    for dataset in ["train"]:
        file=open(os.path.join(WORKING_PATH,"dataset_text/text_data/",dataset+".txt"),"rb")
        for line in file:
            content=eval(line)
            image=content[0]
            sentence=content[1]
            group=content[2]
            if os.path.isfile(os.path.join('/root/autodl-tmp/dataset_image/',"dataset_image",image+".jpg")):
                train_set.append([content[0],content[1],content[2]])
    for dataset in ["valid"]:
        file=open(os.path.join(WORKING_PATH,"dataset_text/text_data/",dataset+".txt"),"rb")
        for line in file:
            content=eval(line)
            image=content[0]
            sentence=content[1]
            group=content[3] #2 hashtag
            if os.path.isfile(os.path.join('/root/autodl-tmp/dataset_image/',"dataset_image",image+".jpg")):
                val_set.append([content[0],content[1],content[3],content[2]])
    for dataset in ["test"]:
        file=open(os.path.join(WORKING_PATH,"dataset_text/text_data/",dataset+".txt"),"rb")
        for line in file:
            content=eval(line)
            image=content[0]
            sentence=content[1]
            group=content[3] #2 is the 
            if os.path.isfile(os.path.join('/root/autodl-tmp/dataset_image/',"dataset_image",image+".jpg")):
                test_set.append([content[0],content[1],content[3],content[2]])
    return train_set, val_set, test_set
    
def clean(dataset):
    dataset_ = []
    for sample in dataset:
        line = sample[1].strip()
        if "sarcasm" in line:
            continue
        if "sarcastic" in line:
            continue
        if "reposting" in line:
            continue
        if "<url>" in line:
            continue
        if "joke" in line:
            continue
        if "humour" in line:
            continue
        if "humor" in line:
            continue
        if "jokes" in line:
            continue
        if "irony" in line:
            continue
        if "ironic" in line:
            continue
        if "exgag" in line:
            continue
        sample[1] = line
        dataset_.append(sample)
    return dataset_


train_set, val_set, test_set = load_data()
trainset = clean(train_set)
valset = clean(val_set)
testset = clean(test_set)
img_path = "/root/autodl-tmp/dataset_image/dataset_image/"
model_name = 'B_32'
vit_model = ViT(model_name, pretrained=True)
tfms = transforms.Compose([transforms.Resize(vit_model.image_size), transforms.ToTensor(), 
                            transforms.Normalize([0.5, 0.5, 0.5], [0.5, 0.5, 0.5]),])
embedding = []
vit_model.__delattr__("fc")
vit_model.cuda()
vit_model.eval()
_t = {'misc' : Timer()}
count = 0
for sample in trainset:
    _t['misc'].tic()
    img = os.path.join(img_path,sample[0]+".jpg")
    index = imgs_url.index(img)
    box = imgs_boxes[index]
    boxes = box[1:-1].split('\n')
    img = Image.open(img)
    img1 = tfms(img).unsqueeze(0)
    with torch.no_grad():
        img1 = vit_model(img1.cuda())[0,:-1,:]
    img_mean = torch.mean(img1, dim=0).unsqueeze(dim=0)
    imgs_mean = []
    imgs_mean.append(img_mean)
    for box in boxes:
        box = box.replace("[","")
        box = box.replace("]","")
        box = box.split('\t')[0]
        dig_box  = map(float, re.findall(r'[+-]?[0-9.]+', box))
        dig_box = list(dig_box) 
        print(dig_box)
        crop_Image = img.crop((dig_box[0], dig_box[1], dig_box[2], dig_box[3]))
        img1 = tfms(crop_Image).unsqueeze(0)
        with torch.no_grad():
            img1 = vit_model(img1.cuda())[0,:-1,:]
        img_mean = torch.mean(img1, dim=0).unsqueeze(dim=0)
        imgs_mean.append(img_mean)
    imgs_mean = torch.cat(imgs_mean, dim=0)
    embedding.append(imgs_mean.cpu())
    _t['misc'].toc()
    if (count % 100) == 0:
        print ('{:d}/{:d} {:.3f}s (projected finish: {:.2f} hours)' \
                .format(count+1, len(trainset), _t['misc'].average_time,
                _t['misc'].average_time*(len(trainset)-count)/3600))
    count += 1
torch.save(embedding, "/root/autodl-tmp/twitter/img_emb/train_box.pt")